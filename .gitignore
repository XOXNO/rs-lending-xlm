**/.certora_internal/

# Fuzz artifacts (mirrors fuzz/.gitignore)
fuzz/corpus/
fuzz/artifacts/
fuzz/coverage/

# Claude Code runtime
.claude/

# Secrets and local config (NEVER commit these)
.env
.env.local
.env.*.local
**/wallets/
**/deploy.json
**/upgrade.json
*.interaction.json

# Coverage
lcov.info
*.profraw

# Logs and temp
*.log
*.tmp
*.swp
*.swo

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Node tooling
**/node_modules/
